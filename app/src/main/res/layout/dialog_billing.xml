<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Billing"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Nhap thong tin giao hang va thanh toan"
        android:textColor="#666666" />

    <EditText
        android:id="@+id/etReceiverName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Nguoi nhan"
        android:inputType="textPersonName" />

    <EditText
        android:id="@+id/etPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="So dien thoai"
        android:inputType="phone" />

    <EditText
        android:id="@+id/etShippingAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Dia chi giao hang"
        android:inputType="textPostalAddress"
        android:minLines="2" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Phuong thuc thanh toan"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rgPaymentMethod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">

        <RadioButton
            android:id="@+id/rbCod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="COD (Nhan hang tra tien)" />

        <RadioButton
            android:id="@+id/rbVnpay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VNPay (Mock thanh cong)" />
    </RadioGroup>

    <TextView
        android:id="@+id/tvBillingAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Tong thanh toan: 0 d"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnConfirmPayment"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#6200EE"
        android:text="Thanh toan"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />
</LinearLayout>
