<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <!-- ===== RECEIVED (left) ===== -->
    <LinearLayout
        android:id="@+id/layoutReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:maxWidth="280dp"
        android:visibility="gone">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAvatarReceived"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_avatar"
            android:scaleType="centerCrop"
            android:layout_marginEnd="8dp"
            android:layout_gravity="bottom"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNameReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/txtMessageReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_received"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txtTimeReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== SENT (right) ===== -->
    <LinearLayout
        android:id="@+id/layoutSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:maxWidth="280dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/txtNameSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/txtMessageSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_sent"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/txtTimeSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAvatarSent"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_avatar"
            android:scaleType="centerCrop"
            android:layout_marginStart="8dp"
            android:layout_gravity="bottom"
            app:shapeAppearanceOverlay="@style/CircleImage" />

    </LinearLayout>

</FrameLayout>
