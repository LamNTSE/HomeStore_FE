<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Product info -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgWriteFbProduct"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_image_placeholder"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvWriteFbProductName"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#222"
                android:maxLines="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Rating row -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <RatingBar
                    android:id="@+id/rbWriteFbRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="5"
                    android:scaleX="0.75"
                    android:scaleY="0.75"
                    android:transformPivotX="0dp"/>

                <TextView
                    android:id="@+id/tvWriteFbRatingText"
                    android:layout_margin="2dp"
                    android:textColor="#128A17"
                    android:textStyle="bold"
                    android:textSize="4pt"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Comment -->
    <EditText
        android:id="@+id/edtWriteFbComment"
        android:hint="Viết đánh giá..."
        android:minLines="2"
        android:maxLines="4"
        android:layout_marginTop="10dp"
        android:textSize="14sp"
        android:padding="10dp"
        android:background="@drawable/bg_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Admin reply -->
    <LinearLayout
        android:id="@+id/layoutAdminReply"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:background="#E3F2FD"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Cửa hàng phản hồi:"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#1976D2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvAdminReplyText"
            android:textSize="13sp"
            android:textColor="#333"
            android:layout_marginTop="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Save button -->
    <Button
        android:id="@+id/btnSaveFeedback"
        android:text="Lưu đánh giá"
        android:backgroundTint="#FF5722"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_width="wrap_content"
        android:layout_height="48dp"/>

</LinearLayout>